# Copy this file to .env and fill in values
# Environment variables override config/config.yaml (prefix: LLM_ROUTER_)

LLM_ROUTER_SERVER_PORT=8080
LLM_ROUTER_SERVER_READ_TIMEOUT=30s
LLM_ROUTER_SERVER_WRITE_TIMEOUT=60s

LLM_ROUTER_DATABASE_URL=postgres://llmrouter:llmrouter@localhost:5433/llmrouter?sslmode=disable
LLM_ROUTER_DATABASE_MAX_CONNECTIONS=20

LLM_ROUTER_REDIS_ADDR=localhost:6380

LLM_ROUTER_LOG_LEVEL=info
LLM_ROUTER_LOG_FORMAT=text
