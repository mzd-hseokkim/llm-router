# Stage 1: Build
FROM golang:1.23-bookworm AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build \
    -ldflags="-s -w" \
    -o /app/bin/gateway \
    ./cmd/gateway

# Stage 2: Runtime
FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=builder /app/bin/gateway /gateway
COPY --from=builder /app/config /config

EXPOSE 8080

ENTRYPOINT ["/gateway"]
